---
import '../styles/global.css';
const { title = 'Movies with Avi', dark = false } = Astro.props;
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content="One guy, 200+ movie reviews, and a food pairing for almost every one. Tell me what you're in the mood for." />
  <link rel="icon" href="/favicon.ico" sizes="16x16" />
  <link rel="icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
  <link rel="icon" type="image/png" href="/favicon-512.png" sizes="512x512" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,800&family=Source+Serif+4:opsz,ital,wght@8..60,0,400;8..60,0,600;8..60,1,400&family=Spline+Sans+Mono:wght@400;600&display=swap" rel="stylesheet" />
</head>
<body class={dark ? 'body-dark' : ''}>
  <nav class={`nav ${dark ? 'nav-dark' : ''}`}>
    <a class="logo" href="/">Movies with <em>Avi</em></a>
    <div>
      <a class="link" href="/#tonight">Tonight's pick</a>
      <a class="link" href="/browse/">Browse the library</a>
    </div>
  </nav>
  <slot />
  <footer style="text-align:center; padding: 46px 20px 34px; color: var(--ink-soft); font-size:.85rem;">
    <span class="mono">Movies with Avi · est. on Instagram, now playing everywhere</span><br/>
    <a href="https://www.instagram.com/movieswithavi/" rel="noopener">Instagram</a>
  </footer>
</body>
</html>
