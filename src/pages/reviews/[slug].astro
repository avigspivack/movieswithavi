---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const reviews = await getCollection('reviews');
  return reviews.map(r => ({ params: { slug: r.id }, props: { review: r } }));
}
const { review } = Astro.props;
const d = review.data;
const { Content } = await render(review);
---
<Base title={`${d.title} — Movies with Avi`}>
  <style>
    .review { max-width: 780px; margin: 0 auto; padding: 26px 22px 60px; }
    .top { display: grid; grid-template-columns: 220px 1fr; gap: 28px; align-items: start; }
    .top img { border-radius: 14px; box-shadow: 0 10px 30px rgba(142,35,32,.18); }
    h1 { font-size: clamp(1.8rem, 4.4vw, 2.7rem); letter-spacing: -.02em; line-height: 1.06; }
    .date { font-family: var(--font-mono); font-size: .78rem; color: var(--ink-soft); margin: 8px 0 12px; }
    .verdict { font-family: var(--font-display); font-weight: 600; font-size: .95rem; margin-top: 8px; color: var(--seat-deep); }
    .one { font-style: italic; font-size: 1.08rem; margin-top: 14px; color: var(--ink-soft); }
    .catline { margin-top: 14px; display: flex; flex-wrap: wrap; gap: 7px; }
    .catline a { font-family: var(--font-display); font-weight: 600; font-size: .78rem; text-decoration: none; background: #fff; border: 1.5px solid rgba(42,30,27,.15); padding: 5px 12px; border-radius: 999px; color: var(--ink-soft); }
    .sec { margin-top: 30px; }
    .lab { font-family: var(--font-mono); font-size: .72rem; font-weight: 600; letter-spacing: .16em; color: var(--seat-red); }
    .sec .body { margin-top: 8px; font-size: 1.04rem; }
    .back { display: inline-block; margin-top: 40px; font-family: var(--font-display); font-weight: 700; text-decoration: none; }
    @media (max-width: 640px) { .top { grid-template-columns: 1fr; } .top img { max-width: 260px; } }
  </style>
  <article class="review">
    <div class="top">
      {d.image && <img src={d.image} alt={`Poster for ${d.title}`} />}
      <div>
        <h1>“{d.title}”</h1>
        <div class="date">{d.date}</div>
        {d.ratingNum != null && (
          <span class="cells">
            {[0,1,2,3].map(i => (
              <span class="cell"><i style={`width:${Math.max(0, Math.min(1, d.ratingNum - i)) * 100}%`}></i></span>
            ))}
            <span class="rnum">{d.ratingNum.toFixed(2)} / 4</span>
          </span>
        )}
        {d.rating && <div class="verdict">{d.rating.replace(/^[\d.]+\/4\s*/, '')}</div>}
        {d.oneLine && <p class="one">{d.oneLine}</p>}
        <div class="catline">
          {d.categories.map(c => <a href={`/browse/?cat=${encodeURIComponent(c)}`}>{c}</a>)}
        </div>
      </div>
    </div>

    <div class="sec"><span class="lab">THE DEETS</span><div class="body"><Content /></div></div>
    {d.perfectFor && <div class="sec"><span class="lab">PERFECT FOR</span><div class="body">{d.perfectFor}</div></div>}
    {d.whereToWatch && <div class="sec"><span class="lab">WHERE TO WATCH</span><div class="body">{d.whereToWatch}</div></div>}
    {d.foodPairing && <div class="sec"><span class="lab">FOOD PAIRING</span><div class="body">{d.foodPairing}</div></div>}

    <a class="back" href="/browse/">← Back to the library</a>
  </article>
</Base>
