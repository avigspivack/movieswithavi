---
import Base from '../layouts/Base.astro';
---
<Base dark={true}>
  <style>
    body.body-dark { background: var(--house-dark); }
    .hero {
      background: radial-gradient(120% 90% at 50% 0%, var(--house-mid) 0%, var(--house-dark) 62%);
      color: var(--cream); padding: 30px 22px 90px; position: relative; overflow: hidden;
    }
    .hero-grid { max-width: 1080px; margin: 0 auto; display: grid; grid-template-columns: 1.15fr .85fr; gap: 40px; align-items: center; }
    .hero h1 { font-size: clamp(2.1rem, 5.4vw, 3.6rem); line-height: 1.04; letter-spacing: -.02em; font-weight: 800; }
    .hero h1 span { color: var(--butter); }
    .hero .sub { font-family: var(--font-body); font-style: italic; color: rgba(246,239,228,.75); margin: 16px 0 30px; font-size: 1.05rem; }
    .hero-photo { border-radius: 18px; border: 3px solid var(--seat-deep); box-shadow: 0 24px 60px rgba(0,0,0,.5); transform: rotate(1.4deg); }
    .ask { display: flex; gap: 10px; }
    .ask input {
      flex: 1; font: 1rem var(--font-body); padding: 15px 18px; border-radius: 12px;
      border: 2px solid var(--seat-deep); background: rgba(246,239,228,.07); color: var(--cream);
    }
    .ask input::placeholder { color: rgba(246,239,228,.45); }
    .ask input:focus { border-color: var(--seat-red); outline: none; }
    .ask button {
      background: var(--seat-red); color: #fff; border: none; border-radius: 12px;
      padding: 0 24px; font-weight: 800; font-size: 1rem; letter-spacing: .01em;
    }
    .ask button:hover { background: var(--seat-deep); }
    .hints { margin-top: 14px; display: flex; flex-wrap: wrap; gap: 8px; }
    .hint { background: transparent; border: 1.5px solid rgba(246,239,228,.25); color: rgba(246,239,228,.8); border-radius: 999px; padding: 6px 13px; font-size: .82rem; font-weight: 600; }
    .hint:hover { border-color: var(--butter); color: var(--butter); }

    /* the ticket stub — signature element */
    #stub-zone { max-width: 660px; margin: 0 auto; padding: 0 22px; }
    .stub {
      background: var(--cream); color: var(--ink); border-radius: 14px 14px 4px 4px;
      margin-top: -56px; position: relative; box-shadow: 0 18px 44px rgba(0,0,0,.45);
      animation: print .5s cubic-bezier(.2,.9,.3,1.1);
    }
    @keyframes print { from { transform: translateY(26px); opacity: 0; } to { transform: none; opacity: 1; } }
    .stub::after { /* perforated tear edge */
      content: ""; display: block; height: 14px;
      background: radial-gradient(circle at 7px 0, transparent 6px, var(--cream) 7px) 0 0 / 22px 14px repeat-x;
      transform: translateY(13px);
    }
    .stub-head { display:flex; justify-content: space-between; align-items:center; padding: 14px 20px 0; }
    .stub-head .adm { font-family: var(--font-mono); font-size: .7rem; letter-spacing: .14em; color: var(--seat-red); font-weight: 600; }
    .stub-body { padding: 10px 20px 20px; display: grid; grid-template-columns: 92px 1fr; gap: 16px; }
    .stub-body img { border-radius: 8px; aspect-ratio: 3/4; object-fit: cover; }
    .stub h2 { font-size: 1.45rem; letter-spacing: -.01em; line-height: 1.1; }
    .stub .why { font-size: .93rem; color: var(--ink-soft); margin-top: 6px; }
    .stub .pair { font-size: .88rem; margin-top: 8px; }
    .stub .pair b { font-family: var(--font-mono); font-size: .7rem; letter-spacing: .12em; color: var(--seat-red); }
    .stub-actions { display: flex; gap: 12px; padding: 0 20px 18px; }
    .stub-actions a, .stub-actions button {
      font-family: var(--font-display); font-weight: 700; font-size: .9rem; border-radius: 10px; padding: 9px 16px; text-decoration: none;
    }
    .stub-actions a { background: var(--seat-red); color: #fff; }
    .stub-actions button { background: none; border: 1.5px solid rgba(42,30,27,.25); color: var(--ink-soft); }
    .runners { padding: 0 20px 20px; font-size: .85rem; color: var(--ink-soft); }
    .runners a { color: var(--seat-red); font-weight: 600; }

    .browse-tease { text-align: center; padding: 84px 22px 30px; }
    .browse-tease h2 { font-size: 1.6rem; color: var(--cream); letter-spacing: -.01em; }
    .browse-tease p { color: rgba(246,239,228,.65); margin: 8px 0 22px; }
    .browse-tease a { display: inline-block; background: transparent; border: 2px solid var(--seat-red); color: var(--cream); font-family: var(--font-display); font-weight: 800; text-decoration: none; padding: 13px 26px; border-radius: 12px; }
    .browse-tease a:hover { background: var(--seat-red); }

    @media (max-width: 780px) {
      .hero-grid { grid-template-columns: 1fr; }
      .hero-photo { max-width: 340px; margin: 0 auto; transform: rotate(0deg); }
      .ask { flex-direction: column; }
      .ask button { padding: 14px; }
      .stub { margin-top: -40px; }
    }
    @media (prefers-reduced-motion: reduce) { .stub { animation: none; } }
  </style>

  <section class="hero" id="tonight">
    <div class="hero-grid">
      <div>
        <h1>What do you want to watch <span>tonight?</span></h1>
        <p class="sub">Describe the mood in a few words — I've watched everything so you don't have to.</p>
        <div class="ask">
          <input id="mood" type="text" placeholder="e.g. french heist, something fun" autocomplete="off" />
          <button id="pick">Pick for me</button>
        </div>
        <div class="hints" id="hints">
          <button class="hint">a tense thriller</button>
          <button class="hint">foodie movie night</button>
          <button class="hint">smart and funny</button>
          <button class="hint">a hidden foreign gem</button>
          <button class="hint">true story</button>
        </div>
      </div>
      <img class="hero-photo" src="/avi-theater-hero.jpg" alt="Avi sitting alone in a red-seated movie theater, review notes in hand" width="1223" height="1035" />
    </div>
  </section>

  <div id="stub-zone" aria-live="polite"></div>

  <section class="browse-tease">
    <h2>Not feeling decisive?</h2>
    <p>Wander the full library — 200+ reviews, sortable by rating, category, or tag.</p>
    <a href="/browse/">Browse the library →</a>
  </section>

  <script>
    import { recommend } from '../lib/discover.js';
    const input = document.getElementById('mood');
    const zone = document.getElementById('stub-zone');
    const cells = (rn) => rn == null ? '' :
      '<span class="cells">' + [0,1,2,3].map(i =>
        `<span class="cell"><i style="width:${Math.max(0, Math.min(1, rn - i)) * 100}%"></i></span>`).join('') +
      `<span class="rnum">${rn.toFixed(2)} / 4</span></span>`;

    async function run() {
      const q = input.value.trim();
      if (!q) { input.focus(); return; }
      const { pick, runners } = await recommend(q);
      if (!pick) {
        zone.innerHTML = `<div class="stub"><div class="stub-body" style="grid-template-columns:1fr"><div>
          <h2>Stumped me — and that's rare.</h2>
          <p class="why">Try different words, or hit "Pick for me" with the box empty next time you're back — the library is at <a href="/browse/">/browse</a>.</p>
        </div></div></div>`;
        return;
      }
      zone.innerHTML = `
        <div class="stub">
          <div class="stub-head"><span class="adm">ADMIT ONE · AVI'S PICK</span><span class="mono" style="font-size:.7rem">${pick.date}</span></div>
          <div class="stub-body">
            ${pick.image ? `<img src="${pick.image}" alt="">` : ''}
            <div>
              <h2>${pick.title}</h2>
              ${cells(pick.ratingNum)}
              <p class="why">${pick.oneLine || ''}</p>
              ${pick.foodPairing ? `<p class="pair"><b>FOOD PAIRING</b> ${pick.foodPairing}</p>` : ''}
            </div>
          </div>
          <div class="stub-actions">
            <a href="/reviews/${pick.slug}/">Read the review</a>
            <button id="again">Deal me another</button>
          </div>
          ${runners.length ? `<p class="runners">Also in the running: ${runners.map(r => `<a href="/reviews/${r.slug}/">${r.title}</a>`).join(' · ')}</p>` : ''}
        </div>`;
      document.getElementById('again').onclick = run;
      zone.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
    document.getElementById('pick').onclick = run;
    input.addEventListener('keydown', e => { if (e.key === 'Enter') run(); });
    document.getElementById('hints').addEventListener('click', e => {
      const b = e.target.closest('.hint'); if (!b) return;
      input.value = b.textContent; run();
    });
  </script>
</Base>
