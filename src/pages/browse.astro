---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
const reviews = await getCollection('reviews');
const cats = [...new Set(reviews.flatMap(r => r.data.categories))].sort();
---
<Base title="Browse the library — Movies with Avi">
  <style is:global>
    .head { max-width: 1080px; margin: 0 auto; padding: 26px 22px 8px; }
    .head h1 { font-size: clamp(1.7rem, 4vw, 2.4rem); letter-spacing: -.02em; }
    .head p { color: var(--ink-soft); margin-top: 4px; }
    .controls { position: sticky; top: 0; z-index: 5; background: linear-gradient(var(--cream) 80%, transparent); max-width: 1080px; margin: 0 auto; padding: 14px 22px 16px; }
    .row { display: flex; gap: 10px; }
    .row input[type=search] { flex: 1; font: 1rem var(--font-body); padding: 12px 16px; border-radius: 11px; border: 2px solid rgba(42,30,27,.15); background: #fff; }
    .row input:focus { border-color: var(--seat-red); outline: none; }
    .row select { font: .92rem var(--font-display); font-weight: 600; padding: 0 12px; border-radius: 11px; border: 2px solid rgba(42,30,27,.15); background: #fff; color: var(--ink); }
    .chips { display: flex; gap: 8px; overflow-x: auto; padding-top: 12px; scrollbar-width: none; }
    .chips::-webkit-scrollbar { display: none; }
    .count { font-family: var(--font-mono); font-size: .75rem; color: var(--ink-soft); padding-top: 10px; }
    .grid { max-width: 1080px; margin: 0 auto; padding: 4px 22px 70px; display: grid; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr)); gap: 16px; }
    .unused-empty { grid-column: 1/-1; text-align: center; color: var(--ink-soft); padding: 60px 0; }
    .empty a { font-weight: 600; }
  </style>

  <div class="head">
    <h1>The library</h1>
    <p>Every review, growing weekly. Filter by whatever matters tonight.</p>
  </div>

  <div class="controls">
    <div class="row">
      <input id="q" type="search" placeholder="Search titles, moods, food pairings…" />
      <select id="sort" aria-label="Sort by">
        <option value="date">Newest</option>
        <option value="rating">Avi's rating</option>
        <option value="title">A–Z</option>
      </select>
    </div>
    <div class="chips" id="chips" role="group" aria-label="Filter by category">
      <button class="chip" aria-pressed="true" data-c="">All</button>
      {cats.map(c => <button class="chip" aria-pressed="false" data-c={c}>{c}</button>)}
    </div>
    <div class="count" id="count"></div>
  </div>

  <main class="grid" id="grid"></main>

  <script>
    let LIB = [], activeCat = '', term = '', sort = 'date';
    const grid = document.getElementById('grid'), count = document.getElementById('count');
    const cells = (rn) => rn == null ? '' :
      '<span class="cells">' + [0,1,2,3].map(i =>
        `<span class="cell"><i style="width:${Math.max(0, Math.min(1, rn - i)) * 100}%"></i></span>`).join('') +
      `<span class="rnum">${rn.toFixed(2)}</span></span>`;

    function render() {
      let list = LIB.filter(p => {
        if (activeCat && !p.categories.includes(activeCat)) return false;
        if (!term) return true;
        return (p.title + ' ' + (p.oneLine||'') + ' ' + (p.deets||'') + ' ' + (p.foodPairing||'') + ' ' +
                p.categories.join(' ') + ' ' + p.tags.join(' ')).toLowerCase().includes(term);
      });
      list.sort((a, b) => sort === 'date' ? b.date.localeCompare(a.date)
        : sort === 'rating' ? (b.ratingNum||0) - (a.ratingNum||0)
        : a.title.localeCompare(b.title));
      count.textContent = `${list.length} of ${LIB.length} reviews`;
      grid.innerHTML = list.length ? list.map(p => `
        <a class="card" href="/reviews/${p.slug}/">
          ${p.image ? `<img loading="lazy" src="${p.image}" alt="">` : ''}
          <div class="pad">
            <h3>${p.title}</h3>
            <div class="meta">${p.date}</div>
            ${cells(p.ratingNum)}
            <p class="one">${p.oneLine || ''}</p>
          </div>
        </a>`).join('')
        : `<div class="browse-empty">Nothing matches — yet. Try fewer words, or <a href="/#tonight">let me pick for you</a>.</div>`;
    }

    fetch('/library.json').then(r => r.json()).then(d => { LIB = d; render(); });
    document.getElementById('q').oninput = e => { term = e.target.value.trim().toLowerCase(); render(); };
    document.getElementById('sort').onchange = e => { sort = e.target.value; render(); };
    document.getElementById('chips').addEventListener('click', e => {
      const b = e.target.closest('.chip'); if (!b) return;
      activeCat = b.dataset.c;
      document.querySelectorAll('.chip').forEach(x => x.setAttribute('aria-pressed', String(x === b)));
      render();
    });
  </script>
</Base>
